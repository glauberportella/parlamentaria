# ===========================================================================
# Parlamentaria — .gitignore
# ===========================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl

# ---------------------------------------------------------------------------
# Virtual Environment
# ---------------------------------------------------------------------------
.venv/
venv/
env/
.python-version

# ---------------------------------------------------------------------------
# Environment & Secrets
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example

# ---------------------------------------------------------------------------
# Testing & Coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/

# ---------------------------------------------------------------------------
# Linting & Formatting
# ---------------------------------------------------------------------------
.ruff_cache/
.mypy_cache/

# ---------------------------------------------------------------------------
# IDEs & Editors
# ---------------------------------------------------------------------------
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Database (local dev)
# ---------------------------------------------------------------------------
*.db
*.sqlite3

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
docker-compose.override.yml
*.log

# ---------------------------------------------------------------------------
# Celery
# ---------------------------------------------------------------------------
celerybeat-schedule
celerybeat.pid

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.bak
*.tmp
*.temp
.cache/
node_modules/
