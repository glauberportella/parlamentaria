# Banco de Dados
DATABASE_URL=postgresql+asyncpg://parlamentaria:parlamentaria@localhost:5432/parlamentaria

# Redis
REDIS_URL=redis://localhost:6379/0

# API Câmara
CAMARA_API_BASE_URL=https://dadosabertos.camara.leg.br/api/v2
CAMARA_API_RATE_LIMIT=1.0

# Google ADK / LLM
AGENT_MODEL=gemini-2.0-flash
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=https://seu-dominio.com/webhook/telegram
TELEGRAM_WEBHOOK_SECRET=change-me-random-32-chars

# WhatsApp (futuro)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Admin API
ADMIN_API_KEY=change-me-random-64-chars

# Publicação (RSS + Webhooks de Saída)
RSS_BASE_URL=https://parlamentaria.app/rss
RSS_TTL_MINUTES=15
WEBHOOK_DISPATCH_TIMEOUT=10
WEBHOOK_MAX_RETRIES=3
WEBHOOK_CIRCUIT_BREAKER_THRESHOLD=5

# App
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
