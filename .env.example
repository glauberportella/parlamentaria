# Banco de Dados
DATABASE_URL=postgresql+asyncpg://parlamentaria:parlamentaria@localhost:5432/parlamentaria
POSTGRES_USER=parlamentaria
POSTGRES_PASSWORD=parlamentaria
POSTGRES_DB=parlamentaria

# Redis
REDIS_URL=redis://:parlamentaria@localhost:6379/0
REDIS_PASSWORD=parlamentaria

# API Câmara
CAMARA_API_BASE_URL=https://dadosabertos.camara.leg.br/api/v2
CAMARA_API_RATE_LIMIT=1.0

# Google ADK / LLM
AGENT_MODEL=gemini-2.5-flash
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=

# Embeddings — Google gemini-embedding-001 (usa mesma GOOGLE_API_KEY)
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=3072
RAG_SIMILARITY_THRESHOLD=0.3
RAG_MAX_RESULTS=10

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=https://seu-dominio.com/webhook/telegram
TELEGRAM_WEBHOOK_SECRET=change-me-random-32-chars

# WhatsApp (futuro)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Admin API
ADMIN_API_KEY=change-me-random-64-chars

# Publicação (RSS + Webhooks de Saída)
RSS_BASE_URL=https://parlamentaria.app/rss
RSS_TTL_MINUTES=15
WEBHOOK_DISPATCH_TIMEOUT=10
WEBHOOK_MAX_RETRIES=3
WEBHOOK_CIRCUIT_BREAKER_THRESHOLD=5

# App
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

# Resend (https://resend.com — conta gratuita = 100 emails/dia)
RESEND_API_KEY=
EMAIL_FROM=Parlamentaria <noreply@seudominio.com>

# URL base do Magic Link (deve apontar para o dashboard)
MAGIC_LINK_BASE_URL=http://localhost:3000/login/verify

# Demo mode (development only — bypasses email auth)
DEMO_MODE=true
DEMO_USER_EMAIL=demo@parlamentaria.app
DEMO_USER_NOME=Deputado(a) Demo

# Dashboard Parlamentar
DASHBOARD_URL=http://localhost:3000

# Cidadão Site
CIDADAO_SITE_URL=http://localhost:3000

# CORS - se precisar de origins adicionais
# CORS_EXTRA_ORIGINS=https://outro-dominio.com,https://staging.parlamentaria.app

# === Social Media Posting ===
SOCIAL_ENABLED=false
SOCIAL_MODERATION_ENABLED=false
SOCIAL_NETWORKS=twitter,facebook,instagram,linkedin,discord,reddit
SOCIAL_WEEKLY_HOUR=10
SOCIAL_VOTE_THRESHOLD=50
SOCIAL_RELEVANT_TYPES=PEC,MPV,PL,PLP,PDL
SOCIAL_EDUCATIONAL_ENABLED=true
SOCIAL_CTA_URL=https://t.me/ParlamentariaBot
SOCIAL_IMAGES_DIR=/app/data/social_images
SOCIAL_IMAGES_PUBLIC_URL=

# Twitter/X
TWITTER_ENABLED=false
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Facebook
FACEBOOK_ENABLED=false
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# Instagram (requer SOCIAL_IMAGES_PUBLIC_URL para upload de imagens)
INSTAGRAM_ENABLED=false
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# LinkedIn
LINKEDIN_ENABLED=false
LINKEDIN_ORGANIZATION_ID=
LINKEDIN_ACCESS_TOKEN=

# Discord (webhooks por tipo de post)
DISCORD_ENABLED=false
DISCORD_WEBHOOK_VOTACOES=
DISCORD_WEBHOOK_RESUMO=
DISCORD_WEBHOOK_EDUCATIVO=
DISCORD_WEBHOOK_GERAL=

# Reddit
REDDIT_ENABLED=false
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=ParlamentariaBot
REDDIT_PASSWORD=
REDDIT_SUBREDDIT=parlamentaria

# Meta Data Deletion Webhook (LGPD compliance)
META_APP_SECRET=